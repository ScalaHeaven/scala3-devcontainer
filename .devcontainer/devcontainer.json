{
  "name": "Scala 3 Development",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "updateRemoteUserUID": true,
  "remoteUser": "vscode",
  "mounts": [
    "source=${localEnv:HOME}/.ssh,target=/tmp/host-ssh,type=bind,readonly",
    "source=${localEnv:HOME}/.codex,target=/tmp/host-codex,type=bind,readonly"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "openai.chatgpt",
        "scalameta.metals",
        "scala-lang.scala"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "metals.defaultBspToBuildTool": true,
        "metals.serverProperties": [
          "-Xmx2G"
        ]
      }
    }
  },
  "postStartCommand": "bash .devcontainer/post-start.sh",
  "postCreateCommand": "node --version && npm --version && codex --version && scala3 -version && scala3-compiler -version && scala-cli --version && sbt update && sbt --version"
}
